generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id           String @id @default(uuid())
  phone_number String

  is_active   Boolean @default(true)
  is_deleted  Boolean @default(false)
  is_verified Boolean @default(false)

  name              String?
  gender            String?

  is_onboarding_completed Boolean @default(false)
  onboarding_step         Int     @default(1)

  otp_hash       String?
  otp_expires_at DateTime?

  addresses Address[]
  bookings  Booking[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}

model Address {
  id         String   @id @default(uuid())
  user_id    String
  user       Users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  label      String
  line1      String
  area       String
  city       String
  pincode    String
  latitude   Float
  longitude  Float
  is_default Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  bookings Booking[]

  @@index([user_id])
  @@map("addresses")
}

model Discount {
  id                String   @id @default(uuid())
  title             String
  code              String   @unique
  /// Percentage off (e.g. 50 = 50%). Omit if using only a fixed amount.
  percentage        Int?
  /// Fixed currency amount off. Omit if using only percentage. Both may be set if product rules allow.
  amount            Decimal? @db.Decimal(12, 2)
  expires_at        DateTime
  /// Max redemptions across all users (e.g. 100 for “first 100”). Null = unlimited.
  usage_limit_total Int?
  /// How many times this code has been applied (increment at booking time).
  usage_count       Int      @default(0)
  /// Display text e.g. "First 100 bookings", "First booking only"
  limit_label       String?
  is_active         Boolean  @default(true)
  is_deleted        Boolean  @default(false)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  bookings Booking[]

  @@map("discounts")
}

/// Snabbit-style home service category (image, copy, do/don’t lists).
model Service {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String
  image_url   String
  /// JSON array of strings — what the pro will do.
  dos         Json     @default("[]")
  /// JSON array of strings — what is out of scope.
  donts       Json     @default("[]")
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  is_deleted  Boolean  @default(false)
  slots       Slot[]
  bookings    Booking[]
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("services")
}

/// Duration tier + pricing. `instant` = ASAP booking tiers; `scheduled` = same tiers when user picks date/time.
model Slot {
  id               String   @id @default(uuid())
  service_id       String
  service          Service  @relation(fields: [service_id], references: [id], onDelete: Cascade)
  slot_type        SlotType @default(instant)
  /// Display label, e.g. "60 min", "2.5 hrs"
  duration_label   String
  /// Minutes for sorting and logic (60, 90, 120, …)
  duration_minutes Int
  price            Decimal  @db.Decimal(12, 2)
  slash_price      Decimal? @db.Decimal(12, 2)
  sort_order       Int      @default(0)
  is_active        Boolean  @default(true)
  is_deleted       Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  bookings Booking[]

  @@unique([service_id, slot_type, duration_minutes])
  @@index([service_id])
  @@map("slots")
}

enum SlotType {
  instant
  scheduled
}

/// Lifecycle: CREATED → ACCEPTED | REJECTED | CANCELLED → … → COMPLETED
enum BookingStatus {
  CREATED
  ACCEPTED
  REJECTED
  ASSIGNING_STAFF
  STAFF_EN_ROUTE
  ARRIVED
  COMPLETED
  CANCELLED
}

model Booking {
  id      String @id @default(uuid())
  user_id String
  user    Users  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  service_id String
  service    Service @relation(fields: [service_id], references: [id], onDelete: Restrict)

  slot_id String
  slot    Slot @relation(fields: [slot_id], references: [id], onDelete: Restrict)

  address_id String
  address    Address @relation(fields: [address_id], references: [id], onDelete: Restrict)

  status BookingStatus @default(CREATED)

  /// Slot price at booking time
  service_charge Decimal @db.Decimal(12, 2)
  platform_fee   Decimal @db.Decimal(12, 2)
  discount_amount Decimal @default(0) @db.Decimal(12, 2)
  total_amount    Decimal @db.Decimal(12, 2)

  discount_id          String?
  discount             Discount? @relation(fields: [discount_id], references: [id], onDelete: SetNull)
  applied_coupon_code  String?

  payment_method String?
  staff_name     String?

  scheduled_at DateTime?

  rating         Int?
  rating_comment String?
  rated_at       DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([status])
  @@map("bookings")
}
