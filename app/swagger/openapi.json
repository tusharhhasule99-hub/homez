{
  "openapi": "3.0.3",
  "info": {
    "title": "HomeZ API",
    "version": "1.0.0",
    "description": "HomeZ backend HTTP API.\n\n## Phone auth (OTP + JWT)\n\n**Register (new user)**\n1. `POST /auth/register` with `phone_number` — creates an unverified account (or resends OTP if signup was already started) and sends a **6-digit OTP** by SMS. The OTP is stored hashed in the database and expires in **10 minutes**.\n2. `POST /auth/verify` with the same `phone_number` and `otp` — validates the code, sets **is_verified** to `true`, and returns a **JWT**.\n\n**Login (verified user)**\n1. `POST /auth/login` with `phone_number` — sends a new OTP (10-minute expiry).\n2. `POST /auth/verify` with `phone_number` and `otp` — returns a **JWT**.\n\n**Single verify endpoint** — After a successful verify, the response includes `flow`: `registration` (account was unverified before this OTP) or `login` (account was already verified; this OTP was for sign-in). You can use the same client code for both.\n\nIndian numbers: you may send `phone_number` with or without a leading `+91`; `+91` is stripped before storage."
  },
  "servers": [
    {
      "url": "/api",
      "description": "API base path"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "OTP-based registration, login, and verify (JWT)"
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Start registration — sends OTP",
        "description": "Creates an unverified user (or resends OTP). Does not return a JWT until you call verify.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PhoneBody"
              },
              "examples": {
                "with_plus91": {
                  "$ref": "#/components/examples/phoneWithPlus91"
                },
                "national_number": {
                  "$ref": "#/components/examples/phoneNational"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "New user created; OTP sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessOtpSent"
                }
              }
            }
          },
          "200": {
            "description": "Existing unverified user; OTP resent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessOtpSent"
                }
              }
            }
          },
          "400": {
            "description": "Validation or business error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "Server misconfiguration (e.g. missing OTP secret)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Start login — sends OTP",
        "description": "Only for users who are already verified. Sends a new OTP; use verify to get a JWT.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PhoneBody"
              },
              "examples": {
                "with_plus91": {
                  "$ref": "#/components/examples/phoneWithPlus91"
                },
                "national_number": {
                  "$ref": "#/components/examples/phoneNational"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessOtpSent"
                }
              }
            }
          },
          "400": {
            "description": "Validation or business error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "Server misconfiguration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/verify": {
      "post": {
        "tags": ["Auth"],
        "summary": "Verify OTP — returns JWT",
        "description": "Same endpoint after register or login. Returns `flow` so you know if this completed registration or login.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyBody"
              },
              "example": {
                "phone_number": "+919876543210",
                "otp": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP valid; JWT issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessVerify"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or expired OTP, or validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "Server misconfiguration (e.g. missing JWT secret)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "examples": {
      "phoneWithPlus91": {
        "summary": "With +91 (India)",
        "description": "You may include +91; it is removed before storage so it matches the national form.",
        "value": {
          "phone_number": "+919876543210"
        }
      },
      "phoneNational": {
        "summary": "National number only",
        "description": "Send the mobile number without country code; same stored value as the +91 example above.",
        "value": {
          "phone_number": "9876543210"
        }
      }
    },
    "schemas": {
      "PhoneBody": {
        "type": "object",
        "required": ["phone_number"],
        "example": {
          "phone_number": "+919876543210"
        },
        "properties": {
          "phone_number": {
            "type": "string",
            "description": "Indian mobile: with or without +91; +91 is stripped before storage.",
            "example": "+919876543210"
          }
        }
      },
      "VerifyBody": {
        "type": "object",
        "required": ["phone_number", "otp"],
        "properties": {
          "phone_number": {
            "type": "string",
            "description": "Same format as register/login."
          },
          "otp": {
            "type": "string",
            "description": "6-digit code from SMS",
            "pattern": "^[0-9]{6}$",
            "example": "123456"
          }
        }
      },
      "PublicUser": {
        "type": "object",
        "description": "User profile (no OTP fields)",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "phone_number": { "type": "string" },
          "is_active": { "type": "boolean" },
          "is_deleted": { "type": "boolean" },
          "is_verified": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "SuccessOtpSent": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {
            "$ref": "#/components/schemas/PublicUser"
          }
        }
      },
      "VerifySuccessData": {
        "type": "object",
        "required": ["token", "user", "flow"],
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT — send as Authorization: Bearer <token> on protected routes"
          },
          "user": {
            "$ref": "#/components/schemas/PublicUser"
          },
          "flow": {
            "type": "string",
            "enum": ["registration", "login"],
            "description": "registration = first-time verify; login = verified user sign-in"
          }
        }
      },
      "SuccessVerify": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {
            "$ref": "#/components/schemas/VerifySuccessData"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string" },
          "code": { "type": "string" }
        }
      }
    }
  }
}
