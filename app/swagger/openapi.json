{
  "openapi": "3.0.3",
  "info": {
    "title": "HomeZ API",
    "version": "1.0.0",
    "description": "HomeZ backend HTTP API.\n\n## Phone auth (OTP + JWT)\n\n**Register** — `POST /auth/register` with `phone_number` only: creates an unverified row (or resends OTP) and sends a **6-digit OTP** (10-minute expiry). Response returns **only** `id` and `phone_number` (no profile yet).\n\n**Verify** — `POST /auth/verify` with `phone_number` and `otp`: message **Verified.** and a **JWT**. Payload includes `is_onboarding_completed`, `onboarding_step`, and full `user` for routing: if `is_onboarding_completed` is `false`, open onboarding; otherwise go to home.\n\n**Login** — `POST /auth/login` then `POST /auth/verify` same as above.\n\n**Onboarding** — `POST /auth/onboarding` with `Authorization: Bearer <JWT>`. **1** — `name`, `gender`. **2** — structured service location saved as the user’s first **`addresses`** row (`line1`, `area`, `city`, `pincode`, `latitude`, `longitude`, optional `label`; same rules as `POST /addresses`). If the user already has 3 saved addresses, step 2 only marks onboarding complete. Then `is_onboarding_completed` is `true`.\n\n**Discounts** — `GET /discounts` and `GET /discounts/code/{code}` require the same Bearer JWT.\n\n**Services** — `GET /services` and `GET /services/{id}` require `Authorization: Bearer <JWT>`. Query **`slot_type`**: `instant` (default), `scheduled`, or `all`. With `include_slots=true` on the list, `slots` is a filtered array; each slot includes its `slot_type`.\n\n**Addresses** — `GET/POST /addresses`, `GET/PATCH/DELETE /addresses/{id}` require JWT. **Max 3 saved addresses** per user; first address is default unless you set `is_default`.\n\nIndian numbers: you may send `phone_number` with or without `+91`; `+91` is stripped before storage."
  },
  "servers": [
    {
      "url": "/api",
      "description": "API base path"
    }
  ],
  "security": [{ "bearerAuth": [] }],
  "tags": [
    {
      "name": "Auth",
      "description": "OTP-based registration, login, and verify (JWT)"
    },
    {
      "name": "Onboarding",
      "description": "Profile and address steps after phone verification (Bearer JWT)"
    },
    {
      "name": "Discounts",
      "description": "Promo codes (Bearer JWT from /auth/verify)"
    },
    {
      "name": "Services",
      "description": "Service catalog and duration/pricing slots (Bearer JWT from /auth/verify)"
    },
    {
      "name": "Addresses",
      "description": "User saved addresses for checkout (Bearer JWT); max 3 per user"
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Start registration — sends OTP",
        "description": "Creates an unverified user (or resends OTP). Returns only `id` and `phone_number`. No JWT until verify.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PhoneBody"
              },
              "examples": {
                "with_plus91": {
                  "$ref": "#/components/examples/phoneWithPlus91"
                },
                "national_number": {
                  "$ref": "#/components/examples/phoneNational"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "New user created; OTP sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessOtpSent"
                }
              }
            }
          },
          "200": {
            "description": "Existing unverified user; OTP resent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessOtpSent"
                }
              }
            }
          },
          "400": {
            "description": "Validation or business error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "Server misconfiguration (e.g. missing OTP secret)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Start login — sends OTP",
        "description": "Only for verified users. Sends OTP; response is only `id` and `phone_number`. Use verify for JWT.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PhoneBody"
              },
              "examples": {
                "with_plus91": {
                  "$ref": "#/components/examples/phoneWithPlus91"
                },
                "national_number": {
                  "$ref": "#/components/examples/phoneNational"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessOtpSent"
                }
              }
            }
          },
          "400": {
            "description": "Validation or business error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "Server misconfiguration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/verify": {
      "post": {
        "tags": ["Auth"],
        "summary": "Verify OTP — returns JWT",
        "description": "Same endpoint after register or login. Message is **Verified.** Includes `is_onboarding_completed`, `onboarding_step`, and `user` so the client can open onboarding (step 1 or 2) or home.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyBody"
              },
              "example": {
                "phone_number": "+919876543210",
                "otp": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP valid; JWT issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessVerify"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or expired OTP, or validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "Server misconfiguration (e.g. missing JWT secret)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/onboarding": {
      "post": {
        "tags": ["Onboarding"],
        "summary": "Submit onboarding step",
        "description": "**Step 1:** name + gender. **Step 2:** structured fields (`line1`, `area`, `city`, `pincode`, map coords, optional `label`) — creates a row in **`addresses`** if the user has fewer than 3; otherwise only completes onboarding. Requires verified user JWT.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OnboardingBody"
              },
              "examples": {
                "step1": {
                  "summary": "Step 1 — name & gender",
                  "value": { "step": 1, "name": "Priya Sharma", "gender": "female" }
                },
                "step2": {
                  "summary": "Step 2 — structured address (saved to addresses table)",
                  "value": {
                    "step": 2,
                    "label": "Home",
                    "line1": "123 Main Street",
                    "area": "Andheri West",
                    "city": "Mumbai",
                    "pincode": "400058",
                    "latitude": 19.1364,
                    "longitude": 72.8296
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Step saved; returns updated user profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessOnboarding"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "403": {
            "description": "Phone not verified",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "409": {
            "description": "Wrong step order or onboarding already finished",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/discounts": {
      "get": {
        "tags": ["Discounts"],
        "summary": "List available discounts",
        "description": "Requires `Authorization: Bearer <JWT>`. Only `is_active: true`, `is_deleted: false`, unexpired discounts. If `usage_limit_total` is set, rows where `usage_count` has reached that cap are omitted. If `usage_limit_total` is null, unlimited until expiry. Increment `usage_count` when a booking applies the code.",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of discounts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessDiscountList"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/discounts/code/{code}": {
      "get": {
        "tags": ["Discounts"],
        "summary": "Look up a discount by code",
        "description": "Requires `Authorization: Bearer <JWT>`. Code is matched case-insensitively (stored uppercase). Returns 404 if unknown, 400 if expired or sold out.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "FIRST50"
          }
        ],
        "responses": {
          "200": {
            "description": "Discount is valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessDiscountOne"
                }
              }
            }
          },
          "400": {
            "description": "Expired, inactive, or usage limit reached",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "Unknown code",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/services": {
      "get": {
        "tags": ["Services"],
        "summary": "List services",
        "description": "Requires `Authorization: Bearer <JWT>`. Optional `include_slots=true` to embed a **`slots` array** filtered by `slot_type` (default **instant**).",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "include_slots",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": false },
            "description": "When true, include `slots` for each service."
          },
          {
            "name": "slot_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["instant", "scheduled", "all"],
              "default": "instant"
            },
            "description": "Which slot rows to return when `include_slots` is true. `all` returns both instant and scheduled tiers."
          }
        ],
        "responses": {
          "200": {
            "description": "Service list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessServiceList" }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/services/{id}": {
      "get": {
        "tags": ["Services"],
        "summary": "Get one service with slots",
        "description": "Requires `Authorization: Bearer <JWT>`. Returns a **`slots` array** filtered by `slot_type` (default **instant**): duration, price, slash price.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "slot_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["instant", "scheduled", "all"],
              "default": "instant"
            },
            "description": "`instant` (default), `scheduled`, or `all`."
          }
        ],
        "responses": {
          "200": {
            "description": "Service with slots",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessServiceOne" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/addresses": {
      "get": {
        "tags": ["Addresses"],
        "summary": "List my saved addresses",
        "description": "Default address first, then oldest first. Bearer JWT required.",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Address list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessAddressList" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Addresses"],
        "summary": "Add a saved address",
        "description": "Maximum **3** addresses per user. Returns 409 if limit reached. Indian **pincode** must be 6 digits.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddressCreateBody" },
              "example": {
                "label": "Home",
                "line1": "123 Main Street",
                "area": "Andheri West",
                "city": "Mumbai",
                "pincode": "400058",
                "latitude": 19.1364,
                "longitude": 72.8296,
                "is_default": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessAddressOne" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "409": {
            "description": "Address limit (3) reached",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/addresses/{id}": {
      "get": {
        "tags": ["Addresses"],
        "summary": "Get one address",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessAddressOne" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Addresses"],
        "summary": "Update an address",
        "description": "Partial update. Setting `is_default: true` clears default on other addresses.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddressPatchBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessAddressOne" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Addresses"],
        "summary": "Delete an address",
        "description": "If the default is removed, the oldest remaining address becomes default.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessAddressDelete" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Paste the JWT string only (Swagger adds the Bearer prefix). Get it from POST /auth/verify → data.token. Then use Authorize at the top of this page."
      }
    },
    "examples": {
      "phoneWithPlus91": {
        "summary": "With +91 (India)",
        "description": "You may include +91; it is removed before storage so it matches the national form.",
        "value": {
          "phone_number": "+919876543210"
        }
      },
      "phoneNational": {
        "summary": "National number only",
        "description": "Send the mobile number without country code; same stored value as the +91 example above.",
        "value": {
          "phone_number": "9876543210"
        }
      }
    },
    "schemas": {
      "PhoneBody": {
        "type": "object",
        "required": ["phone_number"],
        "example": {
          "phone_number": "+919876543210"
        },
        "properties": {
          "phone_number": {
            "type": "string",
            "description": "Indian mobile: with or without +91; +91 is stripped before storage.",
            "example": "+919876543210"
          }
        }
      },
      "VerifyBody": {
        "type": "object",
        "required": ["phone_number", "otp"],
        "properties": {
          "phone_number": {
            "type": "string",
            "description": "Same format as register/login."
          },
          "otp": {
            "type": "string",
            "description": "6-digit code from SMS",
            "pattern": "^[0-9]{6}$",
            "example": "123456"
          }
        }
      },
      "OtpSentUser": {
        "type": "object",
        "description": "Minimal payload after register/login (OTP phase only)",
        "required": ["id", "phone_number"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "phone_number": { "type": "string" }
        }
      },
      "PublicUser": {
        "type": "object",
        "description": "User profile (no OTP fields)",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "phone_number": { "type": "string" },
          "is_active": { "type": "boolean" },
          "is_deleted": { "type": "boolean" },
          "is_verified": { "type": "boolean" },
          "name": { "type": "string", "nullable": true },
          "gender": {
            "type": "string",
            "nullable": true,
            "enum": ["male", "female", "other"]
          },
          "is_onboarding_completed": {
            "type": "boolean",
            "description": "If false, show onboarding; use onboarding_step for which screen."
          },
          "onboarding_step": {
            "type": "integer",
            "enum": [1, 2],
            "description": "1 = name & gender; 2 = address (until is_onboarding_completed is true)."
          },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "OnboardingStep1": {
        "type": "object",
        "required": ["step", "name", "gender"],
        "properties": {
          "step": { "type": "integer", "enum": [1] },
          "name": { "type": "string", "maxLength": 200 },
          "gender": { "type": "string", "enum": ["male", "female", "other"] }
        }
      },
      "OnboardingStep2": {
        "type": "object",
        "required": ["step"],
        "description": "When the user has **fewer than 3** saved addresses, include `line1`, `area`, `city`, `pincode`, `latitude`, `longitude` (and optional `label`). If they already have **3** addresses, send only `{ \"step\": 2 }` to finish onboarding.",
        "properties": {
          "step": { "type": "integer", "enum": [2] },
          "label": {
            "type": "string",
            "maxLength": 120,
            "description": "Defaults to Home if omitted"
          },
          "line1": { "type": "string" },
          "area": { "type": "string" },
          "city": { "type": "string" },
          "pincode": { "type": "string", "pattern": "^[0-9]{6}$" },
          "latitude": { "type": "number", "format": "double", "minimum": -90, "maximum": 90 },
          "longitude": { "type": "number", "format": "double", "minimum": -180, "maximum": 180 }
        }
      },
      "OnboardingBody": {
        "oneOf": [
          { "$ref": "#/components/schemas/OnboardingStep1" },
          { "$ref": "#/components/schemas/OnboardingStep2" }
        ],
        "discriminator": {
          "propertyName": "step",
          "mapping": {
            "1": "#/components/schemas/OnboardingStep1",
            "2": "#/components/schemas/OnboardingStep2"
          }
        }
      },
      "SuccessOtpSent": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {
            "$ref": "#/components/schemas/OtpSentUser"
          }
        }
      },
      "SuccessOnboarding": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {
            "$ref": "#/components/schemas/PublicUser"
          }
        }
      },
      "VerifySuccessData": {
        "type": "object",
        "required": ["token", "user", "flow", "is_onboarding_completed", "onboarding_step"],
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT — send as Authorization: Bearer <token> on protected routes"
          },
          "user": {
            "$ref": "#/components/schemas/PublicUser"
          },
          "flow": {
            "type": "string",
            "enum": ["registration", "login"],
            "description": "registration = first-time verify; login = returning user sign-in."
          },
          "is_onboarding_completed": {
            "type": "boolean",
            "description": "Duplicate of user.is_onboarding_completed for quick routing after verify."
          },
          "onboarding_step": {
            "type": "integer",
            "enum": [1, 2],
            "description": "Which onboarding screen to show when is_onboarding_completed is false."
          }
        }
      },
      "SuccessVerify": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {
            "$ref": "#/components/schemas/VerifySuccessData"
          }
        }
      },
      "PublicDiscount": {
        "type": "object",
        "description": "percentage and/or amount may be set; both null would be invalid in practice.",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "code": { "type": "string" },
          "percentage": { "type": "integer", "nullable": true, "description": "Percent off, e.g. 50" },
          "amount": { "type": "number", "format": "double", "nullable": true, "description": "Fixed amount off" },
          "expires_at": { "type": "string", "format": "date-time" },
          "usage_limit_total": {
            "type": "integer",
            "nullable": true,
            "description": "Max uses globally; null = unlimited"
          },
          "uses_remaining": {
            "type": "integer",
            "nullable": true,
            "description": "Slots left; null when unlimited"
          },
          "limit_label": {
            "type": "string",
            "nullable": true,
            "description": "Marketing copy e.g. First 100 bookings"
          }
        }
      },
      "SuccessDiscountList": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PublicDiscount" }
          }
        }
      },
      "SuccessDiscountOne": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/PublicDiscount" }
        }
      },
      "PublicSlot": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "slot_type": { "type": "string", "enum": ["instant", "scheduled"] },
          "duration_label": { "type": "string", "example": "60 min" },
          "duration_minutes": { "type": "integer", "example": 60 },
          "price": { "type": "number", "format": "double" },
          "slash_price": { "type": "number", "format": "double", "nullable": true },
          "sort_order": { "type": "integer" }
        }
      },
      "PublicService": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "image_url": { "type": "string", "format": "uri" },
          "dos": { "type": "array", "items": { "type": "string" } },
          "donts": { "type": "array", "items": { "type": "string" } },
          "sort_order": { "type": "integer" },
          "slots": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PublicSlot" },
            "description": "Present when list uses `include_slots=true` or on GET by id; filtered by `slot_type` (default instant)."
          }
        }
      },
      "SuccessServiceList": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PublicService" }
          }
        }
      },
      "SuccessServiceOne": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/PublicService" }
        }
      },
      "PublicAddress": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string", "format": "uuid" },
          "label": { "type": "string", "example": "Home" },
          "line1": { "type": "string" },
          "area": { "type": "string" },
          "city": { "type": "string" },
          "pincode": { "type": "string", "pattern": "^[0-9]{6}$" },
          "latitude": { "type": "number", "format": "double" },
          "longitude": { "type": "number", "format": "double" },
          "is_default": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "AddressCreateBody": {
        "type": "object",
        "required": ["label", "line1", "area", "city", "pincode", "latitude", "longitude"],
        "properties": {
          "label": { "type": "string" },
          "line1": { "type": "string" },
          "area": { "type": "string" },
          "city": { "type": "string" },
          "pincode": { "type": "string", "pattern": "^[0-9]{6}$" },
          "latitude": { "type": "number", "format": "double" },
          "longitude": { "type": "number", "format": "double" },
          "is_default": { "type": "boolean", "default": false }
        }
      },
      "AddressPatchBody": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "line1": { "type": "string" },
          "area": { "type": "string" },
          "city": { "type": "string" },
          "pincode": { "type": "string" },
          "latitude": { "type": "number", "format": "double" },
          "longitude": { "type": "number", "format": "double" },
          "is_default": { "type": "boolean" }
        }
      },
      "SuccessAddressList": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PublicAddress" }
          }
        }
      },
      "SuccessAddressOne": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/PublicAddress" }
        }
      },
      "SuccessAddressDelete": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string" },
          "code": { "type": "string" }
        }
      }
    }
  }
}
