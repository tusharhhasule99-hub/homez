{
  "openapi": "3.0.3",
  "info": {
    "title": "HomeZ API",
    "version": "1.0.0",
    "description": "HomeZ backend HTTP API.\n\n## Phone auth (OTP + JWT)\n\n**Register** — `POST /auth/register` with `phone_number` only: creates an unverified row (or resends OTP) and sends a **6-digit OTP** (10-minute expiry). Response returns **only** `id` and `phone_number` (no profile yet).\n\n**Verify** — `POST /auth/verify` with `phone_number` and `otp`: message **Verified.** and a **JWT**. Payload includes `is_onboarding_completed`, `onboarding_step`, and full `user` for routing: if `is_onboarding_completed` is `false`, open onboarding; otherwise go to home.\n\n**Login** — `POST /auth/login` then `POST /auth/verify` same as above.\n\n**Onboarding** — `POST /auth/onboarding` with `Authorization: Bearer <JWT>`. Two steps: **1** — `name`, `gender` (`male` | `female` | `other`). **2** — `address_formatted`, optional `address_label` (default `Home`), `latitude`, `longitude`. After step 2, `is_onboarding_completed` becomes `true`.\n\nIndian numbers: you may send `phone_number` with or without `+91`; `+91` is stripped before storage."
  },
  "servers": [
    {
      "url": "/api",
      "description": "API base path"
    }
  ],
  "security": [{ "bearerAuth": [] }],
  "tags": [
    {
      "name": "Auth",
      "description": "OTP-based registration, login, and verify (JWT)"
    },
    {
      "name": "Onboarding",
      "description": "Profile and address steps after phone verification (Bearer JWT)"
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Start registration — sends OTP",
        "description": "Creates an unverified user (or resends OTP). Returns only `id` and `phone_number`. No JWT until verify.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PhoneBody"
              },
              "examples": {
                "with_plus91": {
                  "$ref": "#/components/examples/phoneWithPlus91"
                },
                "national_number": {
                  "$ref": "#/components/examples/phoneNational"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "New user created; OTP sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessOtpSent"
                }
              }
            }
          },
          "200": {
            "description": "Existing unverified user; OTP resent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessOtpSent"
                }
              }
            }
          },
          "400": {
            "description": "Validation or business error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "Server misconfiguration (e.g. missing OTP secret)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Start login — sends OTP",
        "description": "Only for verified users. Sends OTP; response is only `id` and `phone_number`. Use verify for JWT.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PhoneBody"
              },
              "examples": {
                "with_plus91": {
                  "$ref": "#/components/examples/phoneWithPlus91"
                },
                "national_number": {
                  "$ref": "#/components/examples/phoneNational"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessOtpSent"
                }
              }
            }
          },
          "400": {
            "description": "Validation or business error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "Server misconfiguration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/verify": {
      "post": {
        "tags": ["Auth"],
        "summary": "Verify OTP — returns JWT",
        "description": "Same endpoint after register or login. Message is **Verified.** Includes `is_onboarding_completed`, `onboarding_step`, and `user` so the client can open onboarding (step 1 or 2) or home.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyBody"
              },
              "example": {
                "phone_number": "+919876543210",
                "otp": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP valid; JWT issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessVerify"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or expired OTP, or validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "Server misconfiguration (e.g. missing JWT secret)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/onboarding": {
      "post": {
        "tags": ["Onboarding"],
        "summary": "Submit onboarding step",
        "description": "**Step 1:** name + gender. **Step 2:** service address + map coordinates. Requires verified user JWT.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OnboardingBody"
              },
              "examples": {
                "step1": {
                  "summary": "Step 1 — name & gender",
                  "value": { "step": 1, "name": "Priya Sharma", "gender": "female" }
                },
                "step2": {
                  "summary": "Step 2 — address & pin",
                  "value": {
                    "step": 2,
                    "address_label": "Home",
                    "address_formatted": "123 Main Street, Andheri West, Mumbai - 400058",
                    "latitude": 19.1364,
                    "longitude": 72.8296
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Step saved; returns updated user profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessOnboarding"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "403": {
            "description": "Phone not verified",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "409": {
            "description": "Wrong step order or onboarding already finished",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Paste the JWT string only (Swagger adds the Bearer prefix). Get it from POST /auth/verify → data.token. Then use Authorize at the top of this page."
      }
    },
    "examples": {
      "phoneWithPlus91": {
        "summary": "With +91 (India)",
        "description": "You may include +91; it is removed before storage so it matches the national form.",
        "value": {
          "phone_number": "+919876543210"
        }
      },
      "phoneNational": {
        "summary": "National number only",
        "description": "Send the mobile number without country code; same stored value as the +91 example above.",
        "value": {
          "phone_number": "9876543210"
        }
      }
    },
    "schemas": {
      "PhoneBody": {
        "type": "object",
        "required": ["phone_number"],
        "example": {
          "phone_number": "+919876543210"
        },
        "properties": {
          "phone_number": {
            "type": "string",
            "description": "Indian mobile: with or without +91; +91 is stripped before storage.",
            "example": "+919876543210"
          }
        }
      },
      "VerifyBody": {
        "type": "object",
        "required": ["phone_number", "otp"],
        "properties": {
          "phone_number": {
            "type": "string",
            "description": "Same format as register/login."
          },
          "otp": {
            "type": "string",
            "description": "6-digit code from SMS",
            "pattern": "^[0-9]{6}$",
            "example": "123456"
          }
        }
      },
      "OtpSentUser": {
        "type": "object",
        "description": "Minimal payload after register/login (OTP phase only)",
        "required": ["id", "phone_number"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "phone_number": { "type": "string" }
        }
      },
      "PublicUser": {
        "type": "object",
        "description": "User profile (no OTP fields)",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "phone_number": { "type": "string" },
          "is_active": { "type": "boolean" },
          "is_deleted": { "type": "boolean" },
          "is_verified": { "type": "boolean" },
          "name": { "type": "string", "nullable": true },
          "gender": {
            "type": "string",
            "nullable": true,
            "enum": ["male", "female", "other"]
          },
          "address_label": { "type": "string", "nullable": true },
          "address_formatted": { "type": "string", "nullable": true },
          "latitude": { "type": "number", "format": "double", "nullable": true },
          "longitude": { "type": "number", "format": "double", "nullable": true },
          "is_onboarding_completed": {
            "type": "boolean",
            "description": "If false, show onboarding; use onboarding_step for which screen."
          },
          "onboarding_step": {
            "type": "integer",
            "enum": [1, 2],
            "description": "1 = name & gender; 2 = address (until is_onboarding_completed is true)."
          },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "OnboardingStep1": {
        "type": "object",
        "required": ["step", "name", "gender"],
        "properties": {
          "step": { "type": "integer", "enum": [1] },
          "name": { "type": "string", "maxLength": 200 },
          "gender": { "type": "string", "enum": ["male", "female", "other"] }
        }
      },
      "OnboardingStep2": {
        "type": "object",
        "required": ["step", "address_formatted", "latitude", "longitude"],
        "properties": {
          "step": { "type": "integer", "enum": [2] },
          "address_label": {
            "type": "string",
            "maxLength": 120,
            "description": "Defaults to Home if omitted"
          },
          "address_formatted": { "type": "string" },
          "latitude": { "type": "number", "format": "double", "minimum": -90, "maximum": 90 },
          "longitude": { "type": "number", "format": "double", "minimum": -180, "maximum": 180 }
        }
      },
      "OnboardingBody": {
        "oneOf": [
          { "$ref": "#/components/schemas/OnboardingStep1" },
          { "$ref": "#/components/schemas/OnboardingStep2" }
        ],
        "discriminator": {
          "propertyName": "step",
          "mapping": {
            "1": "#/components/schemas/OnboardingStep1",
            "2": "#/components/schemas/OnboardingStep2"
          }
        }
      },
      "SuccessOtpSent": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {
            "$ref": "#/components/schemas/OtpSentUser"
          }
        }
      },
      "SuccessOnboarding": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {
            "$ref": "#/components/schemas/PublicUser"
          }
        }
      },
      "VerifySuccessData": {
        "type": "object",
        "required": ["token", "user", "flow", "is_onboarding_completed", "onboarding_step"],
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT — send as Authorization: Bearer <token> on protected routes"
          },
          "user": {
            "$ref": "#/components/schemas/PublicUser"
          },
          "flow": {
            "type": "string",
            "enum": ["registration", "login"],
            "description": "registration = first-time verify; login = returning user sign-in."
          },
          "is_onboarding_completed": {
            "type": "boolean",
            "description": "Duplicate of user.is_onboarding_completed for quick routing after verify."
          },
          "onboarding_step": {
            "type": "integer",
            "enum": [1, 2],
            "description": "Which onboarding screen to show when is_onboarding_completed is false."
          }
        }
      },
      "SuccessVerify": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {
            "$ref": "#/components/schemas/VerifySuccessData"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string" },
          "code": { "type": "string" }
        }
      }
    }
  }
}
